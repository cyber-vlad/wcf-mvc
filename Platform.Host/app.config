<?xml version="1.0" encoding="utf-8" ?>
<configuration>
    <startup> 
        <supportedRuntime version="v4.0" sku=".NETFramework,Version=v4.8" />
    </startup>

	<system.serviceModel>
		<services>
			<service name="Platform.Service.TopicService">
				<endpoint address=""
						  binding="basicHttpBinding"
						  contract="Platform.Service.IService" />

				<endpoint address=""
						  binding="basicHttpsBinding"
						  contract="Platform.Service.IService" />

				<endpoint address=""
						  binding="netTcpBinding"
						  contract="Platform.Service.IService" />
				
				<endpoint address="mex"
						  binding="mexHttpBinding"
						  contract="IMetadataExchange" />

				<endpoint address="mex"
						  binding="mexHttpsBinding"
						  contract="IMetadataExchange" />

				<endpoint address="mex"
						  binding="mexTcpBinding"
						  contract="IMetadataExchange" />

				<host>
					<baseAddresses>
						<add baseAddress="http://localhost:7001/TopicService"/>
						<add baseAddress="https://localhost:7002/TopicService"/>
						<add baseAddress="net.tcp://localhost:7005/TopicService"/>
					</baseAddresses>
				</host>

			</service>
		</services>


		<behaviors>
			<serviceBehaviors>
				<behavior>
					<serviceMetadata httpGetEnabled="True" httpsGetEnabled="True"/>
					<serviceDebug includeExceptionDetailInFaults="True" />
				</behavior>
			</serviceBehaviors>
		</behaviors>
	</system.serviceModel>
</configuration>
